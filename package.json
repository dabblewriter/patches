{
  "name": "@dabble/patches",
  "version": "0.8.21",
  "description": "Immutable JSON Patch implementation based on RFC 6902 supporting operational transformation and last-writer-wins",
  "author": "Jacob Wright <jacwright@gmail.com>",
  "bugs": {
    "url": "https://github.com/dabblewriter/patches/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./net": {
      "import": "./dist/net/index.js",
      "types": "./dist/net/index.d.ts"
    },
    "./webrtc": {
      "import": "./dist/net/webrtc/index.js",
      "types": "./dist/net/webrtc/index.d.ts"
    },
    "./compression": {
      "import": "./dist/compression/index.js",
      "types": "./dist/compression/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./solid": {
      "import": "./dist/solid/index.js",
      "types": "./dist/solid/index.d.ts"
    },
    "./micro": {
      "import": "./dist/micro/index.js",
      "types": "./dist/micro/index.d.ts"
    }
  },
  "files": [
    "package.json",
    "README.md",
    "dist"
  ],
  "homepage": "https://github.com/dabblewriter/patches/",
  "keywords": [
    "immutable",
    "json",
    "patch",
    "rfc6902",
    "operational-transformation",
    "collaborative-editing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dabblewriter/patches.git"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepare": "npm run build",
    "test": "vitest run",
    "tdd": "vitest",
    "format": "prettier --write src/ tests/ docs/",
    "format:check": "prettier --check src/ tests/ docs/",
    "type:check": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "dependencies": {
    "@dabble/delta": "^1.2.5",
    "alphacounter": "^2.1.1",
    "crypto-id": "^0.3.2",
    "easy-signal": "^5.0.5",
    "simple-peer": "^9.11.1",
    "simplified-concurrency": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/simple-peer": "^9.11.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "solid-js": "^1.9.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18",
    "vue": "^3.5.29"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  }
}
